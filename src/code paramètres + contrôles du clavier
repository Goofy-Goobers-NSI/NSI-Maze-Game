difficulty = "Normal"
controls = "ARROWS"

def settings_menu():
    global difficulty, controls
    running = True

    while running:
        screen.fill((255, 255, 255))

          screen.blit(big_font.render("PARAMETRES", True, (0, 0, 0)), (230, 30))
# Difficultés du jeu
          screen.blit(font.render("DIFFICULTE", True, (0, 0, 0)), (80, 120))
          pygame.draw.rect(screen, (200, 200, 200), (80, 160, 150, 50))   # Difficulté EASY
          pygame.draw.rect(screen, (200, 200, 200), (80, 220, 150, 50))   # Difficulté  NORMAL
          pygame.draw.rect(screen, (200, 200, 200), (80, 280, 150, 50))   #Difficulté HARD

          screen.blit(font.render("EASY", True, (0, 0, 0)), (120, 175))
