          pygame.draw.rect(screen, (200, 200, 200), (400, 220, 180, 50))  #Controle WASD
          pygame.draw.rect(screen, (200, 200, 200), (400, 280, 180, 50))  #Controle ZQSD

          screen.blit(font.render("ARROWS", True, (0, 0, 0)), (440, 175))
          screen.blit(font.render("WASD", True, (0, 0, 0)), (450, 235))
          screen.blit(font.render("ZQSD", True, (0, 0, 0)), (450, 295))

          for event in pygame.event.get():
            if event.type == pygame.MOUSEBUTTONDOWN:
                x, y = pygame.mouse.get_pos()

# Difficulté
                if 80 < x < 230 and 160 < y < 210:
                    difficulty = "Easy"
                if 80 < x < 230 and 220 < y < 270:
                    difficulty = "Normal"
                if 80 < x < 230 and 280 < y < 330:
                    difficulty = "Hard"


# Contrôles
                if 400 < x < 580 and 160 < y < 210:
                    controls = "ARROWS"
                if 400 < x < 580 and 220 < y < 270:
                    controls = "WASD"
                if 400 < x < 580 and 280 < y < 330:
                    controls = "ZQSD"

            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    running = False

        pygame.display.update()



